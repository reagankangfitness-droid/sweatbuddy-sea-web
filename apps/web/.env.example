# SweatBuddies Environment Variables
# Copy this file to .env.local and fill in your values

# ==============================================
# DATABASE
# ==============================================
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ==============================================
# CLERK AUTHENTICATION
# ==============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"
CLERK_WEBHOOK_SECRET="whsec_xxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ==============================================
# STRIPE PAYMENTS
# ==============================================
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# Stripe Connect (for host payouts)
# Get this from https://dashboard.stripe.com/settings/connect
STRIPE_CONNECT_CLIENT_ID="ca_xxxxx"

# Platform Fee Settings
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=5
NEXT_PUBLIC_STRIPE_FEE_PERCENT=2.9
NEXT_PUBLIC_STRIPE_FEE_FIXED_CENTS=40

# ==============================================
# GOOGLE MAPS
# ==============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="xxxxx"

# ==============================================
# FILE UPLOADS (UploadThing)
# ==============================================
UPLOADTHING_TOKEN="xxxxx"

# ==============================================
# APP SETTINGS
# ==============================================
NEXT_PUBLIC_APP_URL="https://www.sweatbuddies.co"

# ==============================================
# CONTENT MODERATION
# ==============================================
ANTHROPIC_API_KEY=sk-ant-...

# ==============================================
# P2P MODE
# ==============================================
NEXT_PUBLIC_P2P_ENABLED=true

# ==============================================
# EMAIL (Resend)
# ==============================================
RESEND_API_KEY=re_...

# ==============================================
# ADMIN
# ==============================================
ADMIN_SECRET=your-admin-secret-here
ADMIN_PASSWORD=your-admin-password-here
ADMIN_USER_IDS=clerk_user_id_1,clerk_user_id_2

# ==============================================
# CRON
# ==============================================
CRON_SECRET=your-cron-secret-here

# ==============================================
# SESSION
# ==============================================
SESSION_SECRET=your-session-secret-here

# ==============================================
# WEB PUSH NOTIFICATIONS (VAPID)
# ==============================================
# Generate with: node scripts/generate-vapid-keys.js
VAPID_SUBJECT=mailto:noreply@sweatbuddies.co
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ==============================================
# ERROR TRACKING (Sentry) - optional, disabled if not set
# ==============================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ==============================================
# RATE LIMITING (Upstash Redis) - optional, rate limiting disabled if not set
# ==============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==============================================
# APP CONFIGURATION - optional, have sensible defaults
# ==============================================
NEXT_PUBLIC_BASE_URL="https://www.sweatbuddies.co"
SUPPORT_EMAIL="support@sweatbuddies.co"
ADMIN_EMAIL="admin@sweatbuddies.co"
HELLO_EMAIL="hello@sweatbuddies.co"

# ==============================================
# VERCEL (Auto-populated by Vercel CLI)
# ==============================================
# These are auto-populated when deploying to Vercel
# VERCEL="1"
# VERCEL_ENV="production"
# VERCEL_URL=""
