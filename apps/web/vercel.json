{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-jobs",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/process-event-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-pulse",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/process-nudges",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/review-prompts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/schedule-review-prompts",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/process-post-event-followups",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/process-icebreakers",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/host-weekly-summary",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/draft-post-event-emails",
      "schedule": "0 16 * * *"
    }
  ]
}
