{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-jobs",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/process-event-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/process-reconfirmations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/process-nudges",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/generate-recurring-sessions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/calculate-reliability",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/weekly-pulse",
      "schedule": "0 0 * * 1"
    }
  ]
}
